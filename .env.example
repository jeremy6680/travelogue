DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travelogue

# Use .env.local for your local database.
# Use .env.production only as a local reference for production values.
# In production, configure real secrets in your hosting provider instead.

# ─── Directus (see artifacts/directus/.env for the full config) ──────────────
# Directus uses its own .env file at artifacts/directus/.env.
# The variables below are the ones you must customise before first run.
DIRECTUS_SECRET=replace-with-a-random-32-char-string
DIRECTUS_ADMIN_EMAIL=admin@travelogue.local
DIRECTUS_ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Frontend Vite app (set these in artifacts/travel-blog/.env.local) ─────
# Accepted values for VITE_SITE_LANGUAGES: fr, en, both
VITE_SITE_LANGUAGES=both
