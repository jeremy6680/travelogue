# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8055
PUBLIC_URL=http://localhost:8055

# Allow the Vite dev server to query Directus
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:5173

# ─── Database (reuses the existing Postgres instance) ────────────────────────
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=travelogue
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=replace-with-a-random-32-char-hex-string

# ─── Admin account (used only on first `pnpm bootstrap`) ─────────────────────
ADMIN_EMAIL=admin@travelogue.local
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Storage (local filesystem for media uploads) ────────────────────────────
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# ─── Cache ───────────────────────────────────────────────────────────────────
CACHE_ENABLED=false

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
