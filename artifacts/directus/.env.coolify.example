# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8055
PUBLIC_URL=https://directus.example.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Add your frontend production URL here.
CORS_ENABLED=true
CORS_ORIGIN=https://travelogue.example.com

# ─── Database ────────────────────────────────────────────────────────────────
# Point this to the PostgreSQL instance exposed to Coolify.
DB_CLIENT=pg
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=travelogue
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-password

# ─── Security ────────────────────────────────────────────────────────────────
SECRET=replace-with-a-random-32-char-hex-string

# Used only when bootstrapping a fresh Directus database the first time.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=/data/uploads

# ─── Cache / Logs ────────────────────────────────────────────────────────────
CACHE_ENABLED=false
LOG_LEVEL=info
